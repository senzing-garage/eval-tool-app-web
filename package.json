{
  "name": "senzing-eval-tool-app-web",
  "displayName": "Senzing Eval Tool (Web)",
  "readme": "README.md",
  "version": "0.1.0",
  "publisher": "Senzing",
  "license": "Apache-2.0",
  "author": {
    "name": "Senzing",
    "url": "https://senzing.com"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve @senzing/eval-tool-app-web",
    "start:clean": "rm -rf node_modules && npm i && npm start",
    "start:config": "node ./run/scripts/start-configserver -- grpcConnection=\"http://localhost:8261\" datamartServerUrl=\"http://localhost:8261\" webServerUrl=\"http://localhost:4200\" webServerCspDefaultSrc=\"http://localhost:4200\" webServerStatsWithCredentials=false confServerPortNumber=4201",
    "start:docker": "node ./run/scripts/start-webserver -- grpcConnection=\"http://localhost:8261\" datamartServerUrl=\"http://localhost:8261\"",
    "first-run": "npm install && npm run build:subrepos && npm run build",
    "_postinstall": "npm run build:libs",
    "build": "ng build @senzing/eval-tool-app-web",
    "build:docker": "ng build --configuration production",
    "build:libs": "npm run build:subrepos",
    "build:ui-common": "ng build @senzing/eval-tool-ui-common",
    "build:app": "npm run build:libs && ng build @senzing/eval-tool-app-web",
    "build:grpc-web": "cd lib/sz-sdk-typescript-grpc && npm install && npm run build:web && mkdir -p ../../dist/@senzing && cp -r dist/@senzing/sz-sdk-typescript-grpc-web ../../dist/@senzing/sz-sdk-typescript-grpc-web",
    "build:subrepos": "npm run build:grpc-web && ng build @senzing/eval-tool-ui-common",
    "watch": "ng build --watch --configuration development",
    "test": "ng test @senzing/eval-tool-app-web",
    "e2e": "npx playwright test",
    "e2e:ci": "npx playwright test --config=playwright.ci.config.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/common": "^21.1.4",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@fontsource/material-icons": "^4.2.4",
    "@fontsource/roboto": "^4.2.2",
    "@senzing/sz-sdk-typescript-grpc": "4.0.0-beta.4.0",
    "google-protobuf": "^4.0.1",
    "grpc-web": "^2.0.2",
    "cors": "^2.8.5",
    "d3": "^7.8.4",
    "detect-file-encoding-and-language": "^2.4.0",
    "express": "^5.1.0",
    "glob": "^10.5.0",
    "helmet-csp": "^4.0.0",
    "http-proxy-middleware": "^3.0.0",
    "ngx-json-viewer": "^3.2.1",
    "ngx-webstorage-service": "^5.0.0",
    "pug": "^3.0.0",
    "rxjs": "~7.8.0",
    "sanitize-filename": "^1.6.3",
    "sass": "^1.77.6",
    "serve-static": "^2.2.0",
    "tslib": "^2.5.0",
    "uuid": "^9.0.0",
    "winston": "^3.17.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular-devkit/schematics": "^19.2.12",
    "@angular-eslint/builder": "^19.2.0",
    "@angular-eslint/eslint-plugin": "^19.2.0",
    "@angular-eslint/eslint-plugin-template": "^19.2.0",
    "@angular-eslint/schematics": "^19.2.0",
    "@angular-eslint/template-parser": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/language-service": "^19.2.0",
    "@playwright/test": "1.56.1",
    "@types/d3": "^7.4.0",
    "@types/jest": "^29.5.0",
    "concat": "^1.0.3",
    "concurrently": "^9.2.0",
    "eslint": "^9.34.0",
    "fs-extra": "^11.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ng-packagr": "^19.2.2",
    "rimraf": "^6.0.1",
    "scss-bundle": "^3.1.2",
    "typescript": "~5.7.2"
  }
}
